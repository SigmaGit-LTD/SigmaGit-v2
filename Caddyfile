{
    email bh@sigmagaming.net
}

sigmagit.com {
    handle /health {
        reverse_proxy {$API_UPSTREAM:localhost:3001}
    }

    handle /api/health {
        reverse_proxy {$API_UPSTREAM:localhost:3001}
    }

    handle /ws {
        reverse_proxy {$API_UPSTREAM:localhost:3001}
    }

    handle /v2/* {
        request_body {
            max_size 500MB
        }
        reverse_proxy {$API_UPSTREAM:localhost:3001} {
            flush_interval -1
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
        }
    }

    handle /file/* {
        reverse_proxy {$API_UPSTREAM:localhost:3001}
    }

    @git path_regexp git ^/[^/]+/[^/]+\.git(/.*)?$
    handle @git {
        request_body {
            max_size 100MB
        }
        reverse_proxy {$API_UPSTREAM:localhost:3001} {
            flush_interval -1
            transport http {
                read_timeout 600s
                write_timeout 600s
            }
        }
    }

    handle /api/* {
        reverse_proxy {$API_UPSTREAM:localhost:3001}
    }

    handle {
        reverse_proxy {$WEB_UPSTREAM:localhost:3000}
    }

    @compressible not path /v2/* /file/* /ws
    @compressible not path_regexp git ^/[^/]+/[^/]+\.git(/.*)?$
    encode @compressible zstd gzip

    log {
        output stdout
    }
}

docs.sigmagit.com {
    reverse_proxy {$DOCS_UPSTREAM:localhost:3003}

    encode zstd gzip

    log {
        output stdout
    }
}
